<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console appender for errors and warnings only — routed to stderr
         to keep stdout exclusively for MCP JSON-RPC messages (stdio transport). -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z'} [%thread] [%-5level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File appender for all log levels -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/task-orchestrator.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/task-orchestrator-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z'} [task-orchestrator] [%p] %m%n</pattern>
        </encoder>
    </appender>

    <!-- Root logger: stderr (WARN+) and file (all levels) — nothing to stdout -->
    <root level="${LOG_LEVEL:-INFO}">
        <appender-ref ref="STDERR"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- Suppress verbose MCP SDK internals -->
    <logger name="io.modelcontextprotocol" level="WARN"/>
</configuration>
